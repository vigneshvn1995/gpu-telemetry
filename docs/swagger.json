{
    "swagger": "2.0",
    "info": {
        "description": "Real-time GPU metrics ingestion and GreenOps energy analytics.",
        "title": "GPU Telemetry API",
        "contact": {
            "name": "GPU Telemetry"
        },
        "version": "1.0.0"
    },
    "host": "localhost:8080",
    "basePath": "/",
    "paths": {
        "/api/v1/broker/stats": {
            "get": {
                "description": "Returns real-time message-queue statistics proxied from the broker admin HTTP server.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "broker"
                ],
                "summary": "Broker diagnostics",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.brokerStatsResponse"
                        }
                    },
                    "502": {
                        "description": "Bad Gateway",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    }
                }
            }
        },
        "/api/v1/cluster/anomalies": {
            "get": {
                "description": "Scans recent telemetry for rule-based failure signals such as sudden performance drops.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "cluster"
                ],
                "summary": "Cluster anomaly detection",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Lookback duration (default 30m, e.g. 1h)",
                        "name": "window",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.clusterAnomaliesResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    }
                }
            }
        },
        "/api/v1/cluster/stranded-compute": {
            "get": {
                "description": "Returns GPUs with zero utilisation over the window that are wasting idle power.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "greenops"
                ],
                "summary": "Stranded compute (GreenOps)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "Lookback duration (default 15m, e.g. 30m, 1h)",
                        "name": "window",
                        "in": "query"
                    },
                    {
                        "type": "number",
                        "description": "Max util % to classify as stranded (default 0)",
                        "name": "max_util",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.strandedComputeResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    }
                }
            }
        },
        "/api/v1/gpus": {
            "get": {
                "description": "Returns one entry per unique GPU UUID observed in the telemetry database.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "gpus"
                ],
                "summary": "List GPUs",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.gpuListResponse"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    }
                }
            }
        },
        "/api/v1/gpus/{uuid}/energy": {
            "get": {
                "description": "Computes energy consumption (Wh) and CO₂ estimate (g) for the given GPU UUID.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "greenops"
                ],
                "summary": "GPU energy \u0026 carbon estimate (GreenOps)",
                "parameters": [
                    {
                        "type": "string",
                        "description": "GPU UUID",
                        "name": "uuid",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Start of time range (RFC3339)",
                        "name": "start_time",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "End of time range (RFC3339)",
                        "name": "end_time",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.energyResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    }
                }
            }
        },
        "/api/v1/gpus/{uuid}/telemetry": {
            "get": {
                "description": "Returns time-series telemetry records for the given GPU UUID.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "gpus"
                ],
                "summary": "Get GPU telemetry",
                "parameters": [
                    {
                        "type": "string",
                        "description": "GPU UUID",
                        "name": "uuid",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Filter by metric name (e.g. DCGM_FI_DEV_GPU_UTIL)",
                        "name": "metric_name",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "Start of time range (RFC3339)",
                        "name": "start_time",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "End of time range (RFC3339)",
                        "name": "end_time",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Page size (default 100, max 10000)",
                        "name": "limit",
                        "in": "query"
                    },
                    {
                        "type": "integer",
                        "description": "Page offset (default 0)",
                        "name": "offset",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.telemetryResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    }
                }
            }
        },
        "/api/v1/gpus/{uuid}/telemetry/summary": {
            "get": {
                "description": "Returns P50/P90/P99 percentiles, mean, min, and max for a GPU metric over a time window.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "gpus"
                ],
                "summary": "Telemetry statistical summary",
                "parameters": [
                    {
                        "type": "string",
                        "description": "GPU UUID",
                        "name": "uuid",
                        "in": "path",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Metric name (e.g. DCGM_FI_DEV_GPU_UTIL)",
                        "name": "metric_name",
                        "in": "query",
                        "required": true
                    },
                    {
                        "type": "string",
                        "description": "Start of window (RFC3339)",
                        "name": "start_time",
                        "in": "query"
                    },
                    {
                        "type": "string",
                        "description": "End of window (RFC3339)",
                        "name": "end_time",
                        "in": "query"
                    }
                ],
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "$ref": "#/definitions/main.telemetrySummaryResponse"
                        }
                    },
                    "400": {
                        "description": "Bad Request",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    },
                    "404": {
                        "description": "Not Found",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    },
                    "500": {
                        "description": "Internal Server Error",
                        "schema": {
                            "$ref": "#/definitions/main.problemDetail"
                        }
                    }
                }
            }
        },
        "/health": {
            "get": {
                "description": "Returns 200 OK when the service is up.",
                "produces": [
                    "application/json"
                ],
                "tags": [
                    "ops"
                ],
                "summary": "Liveness probe",
                "responses": {
                    "200": {
                        "description": "OK",
                        "schema": {
                            "type": "object",
                            "additionalProperties": {
                                "type": "string"
                            }
                        }
                    }
                }
            }
        }
    },
    "definitions": {
        "main.anomalyEvent": {
            "type": "object",
            "properties": {
                "description": {
                    "type": "string"
                },
                "detected_at": {
                    "type": "string"
                },
                "drop_delta_pp": {
                    "description": "magnitude of the drop in percentage points",
                    "type": "number"
                },
                "drop_util_pct": {
                    "type": "number"
                },
                "hostname": {
                    "type": "string"
                },
                "kind": {
                    "description": "e.g. \"PerformanceDrop\"",
                    "type": "string"
                },
                "model_name": {
                    "type": "string"
                },
                "peak_util_pct": {
                    "type": "number"
                },
                "uuid": {
                    "type": "string"
                }
            }
        },
        "main.brokerStatsResponse": {
            "type": "object",
            "properties": {
                "active_topics": {
                    "type": "integer"
                },
                "drop_rate_pct": {
                    "description": "TotalDropped / TotalPublished × 100",
                    "type": "number"
                },
                "note": {
                    "type": "string"
                },
                "total_delivered": {
                    "type": "integer"
                },
                "total_dropped": {
                    "type": "integer"
                },
                "total_published": {
                    "type": "integer"
                },
                "total_subscribers": {
                    "type": "integer"
                }
            }
        },
        "main.clusterAnomaliesResponse": {
            "type": "object",
            "properties": {
                "anomaly_count": {
                    "type": "integer"
                },
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/main.anomalyEvent"
                    }
                },
                "since": {
                    "type": "string"
                },
                "window": {
                    "type": "string"
                }
            }
        },
        "main.energyResponse": {
            "type": "object",
            "properties": {
                "avg_power_w": {
                    "type": "number"
                },
                "avg_utilisation_pct": {
                    "type": "number"
                },
                "carbon_grams": {
                    "type": "number"
                },
                "carbon_intensity": {
                    "type": "string"
                },
                "duration_hours": {
                    "type": "number"
                },
                "hostname": {
                    "type": "string"
                },
                "model_name": {
                    "type": "string"
                },
                "power_model_note": {
                    "type": "string"
                },
                "sample_count": {
                    "type": "integer"
                },
                "total_energy_wh": {
                    "type": "number"
                },
                "uuid": {
                    "type": "string"
                },
                "window_end": {
                    "type": "string"
                },
                "window_start": {
                    "type": "string"
                }
            }
        },
        "main.gpuListResponse": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer"
                },
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/storage.GPUSummary"
                    }
                }
            }
        },
        "main.problemDetail": {
            "type": "object",
            "properties": {
                "detail": {
                    "type": "string"
                },
                "status": {
                    "type": "integer"
                },
                "title": {
                    "type": "string"
                },
                "type": {
                    "type": "string"
                }
            }
        },
        "main.strandedComputeResponse": {
            "type": "object",
            "properties": {
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/main.strandedGPUItem"
                    }
                },
                "max_util_pct": {
                    "type": "number"
                },
                "since": {
                    "type": "string"
                },
                "stranded_count": {
                    "type": "integer"
                },
                "total_wasted_co2_g": {
                    "type": "number"
                },
                "total_wasted_wh": {
                    "type": "number"
                },
                "window": {
                    "type": "string"
                }
            }
        },
        "main.strandedGPUItem": {
            "type": "object",
            "properties": {
                "gpu_id": {
                    "type": "string"
                },
                "hostname": {
                    "type": "string"
                },
                "idle_power_w": {
                    "type": "number"
                },
                "model_name": {
                    "type": "string"
                },
                "peak_util_pct": {
                    "description": "highest utilisation seen in window",
                    "type": "number"
                },
                "sample_count": {
                    "description": "number of samples examined",
                    "type": "integer"
                },
                "uuid": {
                    "type": "string"
                },
                "wasted_co2_g": {
                    "type": "number"
                },
                "wasted_energy_wh": {
                    "type": "number"
                }
            }
        },
        "main.telemetryResponse": {
            "type": "object",
            "properties": {
                "count": {
                    "type": "integer"
                },
                "items": {
                    "type": "array",
                    "items": {
                        "$ref": "#/definitions/models.Telemetry"
                    }
                },
                "limit": {
                    "type": "integer"
                },
                "offset": {
                    "type": "integer"
                }
            }
        },
        "main.telemetrySummaryResponse": {
            "type": "object",
            "properties": {
                "max": {
                    "type": "number"
                },
                "mean": {
                    "type": "number"
                },
                "metric_name": {
                    "type": "string"
                },
                "min": {
                    "type": "number"
                },
                "p50": {
                    "type": "number"
                },
                "p90": {
                    "type": "number"
                },
                "p99": {
                    "type": "number"
                },
                "sample_count": {
                    "type": "integer"
                },
                "uuid": {
                    "type": "string"
                },
                "window_end": {
                    "type": "string"
                },
                "window_start": {
                    "type": "string"
                }
            }
        },
        "models.Telemetry": {
            "type": "object",
            "properties": {
                "container": {
                    "description": "Kubernetes context (optional – empty when running bare-metal)",
                    "type": "string"
                },
                "device": {
                    "type": "string"
                },
                "gpu_id": {
                    "type": "string"
                },
                "hostname": {
                    "type": "string"
                },
                "labels": {
                    "description": "Labels carries the full Prometheus label set parsed from the raw CSV\ncolumn.  Consumers that need driver version, job name, instance, etc.\ncan find them here without schema changes.",
                    "type": "object",
                    "additionalProperties": {
                        "type": "string"
                    }
                },
                "metric_name": {
                    "type": "string"
                },
                "model_name": {
                    "type": "string"
                },
                "namespace": {
                    "type": "string"
                },
                "pod": {
                    "type": "string"
                },
                "timestamp": {
                    "description": "Core identity fields",
                    "type": "string"
                },
                "uuid": {
                    "type": "string"
                },
                "value": {
                    "description": "The actual measured value.",
                    "type": "number"
                }
            }
        },
        "storage.GPUSummary": {
            "type": "object",
            "properties": {
                "gpu_id": {
                    "type": "string"
                },
                "hostname": {
                    "type": "string"
                },
                "model_name": {
                    "type": "string"
                },
                "uuid": {
                    "type": "string"
                }
            }
        }
    }
}